{
    "name": "misaf/vendra-subscription",
    "description": "Tenant provisioning orchestration for Vendra applications",
    "license": "MIT",
    "type": "vendra-module",
    "keywords": [
        "laravel",
        "filamentphp",
        "subscription",
        "tenant"
    ],
    "authors": [
        {
            "name": "Ehsan Mahmoodi",
            "email": "misaf.1990@gmail.com",
            "role": "Developer"
        }
    ],
    "homepage": "https://github.com/misaf/vendra-subscription",
    "support": {
        "issues": "https://github.com/misaf/vendra-subscription/issues",
        "source": "https://github.com/misaf/vendra-subscription"
    },
    "require": {
        "php": "^8.3",
        "misaf/vendra-permission": "self.version",
        "misaf/vendra-support": "self.version",
        "misaf/vendra-tenant": "self.version",
        "misaf/vendra-user": "self.version",
        "spatie/laravel-package-tools": "^1.93.1"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24.1",
        "larastan/larastan": "^3.10.0",
        "laravel/boost": "^2.4.12",
        "laravel/pint": "^1.29.3",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/collision": "^8.9.4",
        "orchestra/testbench": "^11.1",
        "pestphp/pest": "^4.7.5",
        "pestphp/pest-plugin-laravel": "^4.1",
        "phpstan/extension-installer": "^1.4.3"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Misaf\\VendraSubscription\\": "src/",
            "Misaf\\VendraSubscription\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Misaf\\VendraSubscription\\Database\\Factories\\": "database/factories/",
            "Misaf\\VendraSubscription\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "phpstan/extension-installer": true
        },
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Misaf\\VendraSubscription\\Providers\\SubscriptionServiceProvider"
            ]
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse",
        "format": "vendor/bin/pint",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage"
    },
    "$schema": "https://getcomposer.org/schema.json"
}
